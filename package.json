{
  "name": "@owndesign/monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter @owndesign/server --filter @owndesign/web dev",
    "desktop:dev": "pnpm --filter @owndesign/desktop dev",
    "desktop:build": "pnpm --filter @owndesign/desktop build",
    "build": "pnpm -r --workspace-concurrency=1 build",
    "lint": "pnpm -r --workspace-concurrency=1 lint",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "test:watch": "pnpm -r --parallel test:watch"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/yazl": "^3.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.59.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
