{
  "name": "@owndesign/server",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@owndesign/core": "workspace:*",
    "ai": "^6.0.191",
    "hono": "^4.12.22",
    "playwright-core": "^1.61.0",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
