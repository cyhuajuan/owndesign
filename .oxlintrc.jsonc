{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "dist/**",
    "build/**",
    ".vite/**",
    "coverage/**",
    "packages/renderer/src/components/ai-elements/**",
    "apps/desktop/src-tauri/resources/**",
    "apps/desktop/src-tauri/target/**"
  ],
  "plugins": ["react"],
  "rules": {
    "react/only-export-components": "off"
  }
}
