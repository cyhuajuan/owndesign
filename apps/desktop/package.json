{
  "name": "@owndesign/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --filter @owndesign/server build && node scripts/prepare-server.mjs && bunx tauri dev",
    "build": "bun run --filter @owndesign/server build && node scripts/prepare-server.mjs && vite build && bunx tauri build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@owndesign/renderer": "workspace:*",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "2.11.2",
    "@tauri-apps/api": "2.11.0"
  }
}
